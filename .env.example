# === Base de données ===
POSTGRES_USER=reception
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=reception_db

# === JWT ===
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_jwt_secret_key

# === Domaine ===
DOMAIN_NAME=reception.mongroupe.com

# === FTP / SFTP ===
FTP_HOST=ftp.mongroupe.com
FTP_USER=user_ftp
FTP_PASSWORD=CHANGE_ME_ftp_password
FTP_PORT=22
FTP_USE_SFTP=true
FTP_PATH_RECEPTIONS=/receptions
FTP_PATH_CODES_BARRES=/codes_barres

# === SMTP ===
SMTP_HOST=smtp.mongroupe.com
SMTP_PORT=587
SMTP_USER=receptions@mongroupe.com
SMTP_PASSWORD=CHANGE_ME_smtp_password
SMTP_USE_TLS=true
MAIL_ACHATS=achats@mongroupe.com

# === Environnement ===
ENVIRONMENT=production
